# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=Document Intelligence Platform
DEBUG=False
API_PREFIX=/api/v1

# ─── Server ────────────────────────────────────────────────────────────────────
# Hugging Face Spaces requires the application to bind to port 7860.
HOST=0.0.0.0
PORT=7860

# ─── Logging ───────────────────────────────────────────────────────────────────
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Set this as a Secret in Hugging Face Spaces settings (never commit the real value).
MONGODB_URI=

# Name of the MongoDB database to use.
DATABASE_NAME=document_intelligence

# ─── LLM ───────────────────────────────────────────────────────────────────────
# Groq API key — obtain from https://console.groq.com
# Set this as a Secret in Hugging Face Spaces settings.
GROQ_API_KEY=

# LLM provider: "groq" or "gpt-oss"
LLM_PROVIDER=groq

# Model identifier sent to the Groq OpenAI-compatible endpoint.
LLM_MODEL=openai/gpt-oss-20b

# ─── Uvicorn ───────────────────────────────────────────────────────────────────
# Number of Uvicorn worker processes.
# Keep at 1 on Hugging Face Spaces (limited CPU). Increase only if needed.
WEB_CONCURRENCY=1